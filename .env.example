# Copy to .env and fill in real values. Never commit .env.

# ── MySQL (required) ─────────────────────────────────────────────────────────
MYSQL_HOST=10.0.0.83
MYSQL_PORT=3306
MYSQL_DB=ruhani
MYSQL_USER=user
MYSQL_PASSWORD=pass

# ── JWT (required) ────────────────────────────────────────────────────────────
# ≥32 random bytes. Generate one with:
#   openssl rand -base64 48
RUHANI_JWT_SECRET=replace-with-a-real-secret-at-least-32-bytes-long

# ── OTP email delivery ────────────────────────────────────────────────────────
# 'log' (default) → OTP printed to stdout (combined with `000000` universal
# bypass, no AWS setup needed for local dev).
# 'ses'           → sends via AWS SES v2 using default credential chain.
RUHANI_EMAIL_PROVIDER=log
RUHANI_EMAIL_FROM=no-reply@saathji.com
RUHANI_AWS_REGION=us-east-2

# Only set when RUHANI_EMAIL_PROVIDER=ses and not using an IAM role:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Optional: rate-limit overrides ────────────────────────────────────────────
# RUHANI_RL_OTP_REQ_PER_EMAIL=5
# RUHANI_RL_OTP_REQ_PER_IP=20
# RUHANI_RL_OTP_VERIFY_PER_EMAIL=10

# ── Optional: host port override ──────────────────────────────────────────────
# BACKEND_PORT=8080
